# ==============================================
# DataTeaCup - Environment Variables
# ==============================================
# Copy this file to .env and update the values.
# DO NOT commit .env to version control.

# ==================== Database ====================
DB_ROOT_PASSWORD=datateacup2026
DB_HOST=mysql
DB_NAME=data_platform
DB_USERNAME=datateacup
DB_PASSWORD=datateacup2026
DB_PORT=3306

# ==================== Redis ====================
REDIS_ENABLED=true
REDIS_PASSWORD=datateacup2026
REDIS_PORT=6379

# ==================== Security ====================
# IMPORTANT: Change this to a secure random 256-bit key in production!
JWT_SECRET=please-change-this-to-a-secure-256bit-secret-key
USER_DEFAULT_PASSWORD=Dp@2024!
JASYPT_PASSWORD=datateacup-encrypt-key

# ==================== License (Optional) ====================
# Put the signed license file at runtime/license/datateacup-license.json.
# Configure a public key only when using a custom license issuer.
DATATEACUP_LICENSE_PUBLIC_KEY=
# Legacy raw keys are accepted only when this hash is explicitly configured.
DATATEACUP_LICENSE_KEY_HASH=

# ==================== Ports ====================
APP_PORT=80
GATEWAY_PORT=8888
API_PORT=8888

# ==================== AI Provider (Optional) ====================
# Supported providers: openai, qwen, deepseek, ollama
# DeepSeek uses an OpenAI-compatible API. Do not commit real API keys.
AI_PROVIDER=deepseek
AI_ENABLED=true
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash

# DeepSeek-specific aliases. These override the generic AI_* values when set.
AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_URL=https://api.deepseek.com
AI_DEEPSEEK_MODEL=deepseek-v4-flash
AI_DEEPSEEK_THINKING_TYPE=disabled
AI_DEEPSEEK_REASONING_EFFORT=high

# ==================== Spring Profile ====================
SPRING_PROFILES_ACTIVE=prod
