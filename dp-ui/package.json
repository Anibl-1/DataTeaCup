{
  "name": "datateacup-frontend",
  "version": "2.1.0",
  "description": "DataTeaCup - Open data integration and analytics platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:docker": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "plop": "plop",
    "lint": "eslint src --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,js,ts,jsx,tsx,css,scss}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "vue-tsc --noEmit",
    "prepare": "cd .. && husky dp-ui/.husky"
  },
  "lint-staged": {
    "*.{vue,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.13",
    "@vicons/ionicons5": "^0.12.0",
    "axios": "^1.6.2",
    "dayjs": "^1.11.10",
    "echarts": "^5.4.3",
    "echarts-wordcloud": "^2.1.0",
    "html2canvas": "^1.4.1",
    "highlight.js": "^11.11.1",
    "jspdf": "^4.0.0",
    "marked": "^17.0.1",
    "naive-ui": "^2.38.1",
    "pinia": "^2.1.7",
    "sockjs-client": "^1.6.1",
    "stompjs": "^2.3.3",
    "vue": "^3.3.4",
    "vue-codemirror": "^6.1.1",
    "vue-draggable-plus": "^0.6.0",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.2.5",
    "vue3-draggable-resizable": "^1.6.5",
    "vue3-grid-layout-next": "^1.0.7",
    "vuedraggable": "^4.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/html2canvas": "^0.5.35",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vue/test-utils": "^2.4.3",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.19.2",
    "fast-check": "^4.5.3",
    "husky": "^9.1.7",
    "jsdom": "^23.0.1",
    "lint-staged": "^16.2.7",
    "plop": "^4.0.1",
    "prettier": "^3.1.0",
    "rollup-plugin-visualizer": "^7.0.0",
    "sharp": "^0.34.5",
    "svgo": "^4.0.0",
    "typescript": "^5.2.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^5.0.0",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-pwa": "^0.17.4",
    "vitest": "^1.0.0",
    "vue-tsc": "^3.3.5"
  }
}
